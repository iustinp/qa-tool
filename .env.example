# Copy to .env in this directory (same folder as index.js):
#   cp .env.example .env
#
# This tool loads ONLY tools/page-pair-diff/.env — not parent repo .env files.

# =============================================================================
# AI — use ONE auth path
# =============================================================================

# Option A (recommended): AWS Bedrock API key + Converse API
AWS_BEARER_TOKEN_BEDROCK=
AWS_REGION=us-east-2
ANTHROPIC_MODEL=global.anthropic.claude-opus-4-5-20251101-v1:0

# Option B: Direct Anthropic API (leave AWS_BEARER_TOKEN_BEDROCK empty)
# ANTHROPIC_API_KEY=

# Option C: Bedrock via AWS SDK + IAM (no bearer token)
# CLAUDE_CODE_USE_BEDROCK=1
# AWS_REGION=us-east-2
# ANTHROPIC_MODEL=global.anthropic.claude-opus-4-5-20251101-v1:0

# =============================================================================
# Rate limiting (vision API)
# =============================================================================
# PPD_MIN_DELAY_MS=500
# PPD_MAX_RPM=30

# =============================================================================
# Capture
# =============================================================================
# PPD_DISMISS_OVERLAYS=1
# PPD_OVERLAY_LAZY_MS=4000
# PPD_OVERLAY_DISMISS_MAX=8
# PPD_GOTO_WAIT_UNTIL=load
# PPD_GOTO_NETWORKIDLE_TIMEOUT_MS=12000

# =============================================================================
# Vision image size (px, longest edge)
# =============================================================================
# PPD_VISION_MAX_LONG_EDGE=1568
# PPD_SEGMENT_VISION_MAX_EDGE=1568
# PPD_MATCH_TARGET_MAX_EDGE=1568
# PPD_MATCH_CROP_MAX_EDGE=800

# =============================================================================
# Screening — see SCREENING.md
# =============================================================================
# PPD_SCREENING=1
# PPD_SCREEN_PASS_SKIP_AI=0

# =============================================================================
# Text audit expansion — see SCREENING.md and INTERACTION.md
# =============================================================================
# PPD_TEXT_EXPANSION=1
# PPD_TEXT_EXPANSION_MODE=selectors
# PPD_INCLUDE_IMAGE_ALT=0

# =============================================================================
# Match strictness
# =============================================================================
# PPD_MATCH_MIN_CONFIDENCE=0.85
# PPD_MATCH_MIN_CONFIDENCE_REORDERED=0.9
# PPD_MATCH_MAX_RELATIVE_VERTICAL_DELTA=0.14
