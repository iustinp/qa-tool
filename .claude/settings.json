{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "\"$CLAUDE_PROJECT_DIR/.claude/hooks/git-tracking-check.sh\"",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
